# Copy this file to .env and fill in your values,
# OR simply run: bash setup.sh (recommended)
#
# .env is gitignored — never commit it to version control.

# Domain
SERVER_NAME=example.com
CONDUIT_PORT=6167

# TURN
TURN_HOST=turn.example.com
TURN_REALM=example.com
TURN_TTL=3600
TURN_SHARED_SECRET=         # generate: openssl rand -hex 32
TURN_LISTENING_IP=          # your server's public IP
TURN_RELAY_IP=              # your server's public IP
TURN_EXTERNAL_IP=           # your server's public IP
TURN_MIN_PORT=50000
TURN_MAX_PORT=50100

# LiveKit
LIVEKIT_API_KEY=            # generate: echo "lk_$(openssl rand -hex 6)"
LIVEKIT_API_SECRET=         # generate: openssl rand -hex 32
LIVEKIT_TURN_USER=lkuser
LIVEKIT_TURN_PASS=lkpass
LIVEKIT_URL=wss://sfu.example.com
LIVEKIT_JWT_PORT=8080

# Caddy / Let's Encrypt
ADMIN_EMAIL=admin@example.com
